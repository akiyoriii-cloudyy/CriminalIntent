<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_window_investigation"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="4dp"
        android:paddingEnd="16dp"
        android:paddingBottom="28dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:cardBackgroundColor="@color/crime_surface"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/crime_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_badge_open"
                    android:paddingStart="12dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="6dp"
                    android:text="@string/crime_detail_header_tag"
                    android:textAllCaps="true"
                    android:textColor="@color/crime_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:typeface="monospace" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/crime_detail_header_title"
                    android:textColor="@color/crime_text_primary"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:typeface="monospace" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/crime_detail_header_copy"
                    android:textColor="@color/crime_text_secondary"
                    android:textSize="15sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/crime_surface_elevated"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/crime_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/crime_title_label"
                    android:textColor="@color/crime_text_muted"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:typeface="monospace" />

                <EditText
                    android:id="@+id/crime_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_input_field"
                    android:hint="@string/crime_title_hint"
                    android:paddingStart="16dp"
                    android:paddingTop="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="16dp"
                    android:textColor="@color/crime_text_primary"
                    android:textColorHint="@color/crime_text_muted" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/crime_details_label"
                    android:textColor="@color/crime_text_muted"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:typeface="monospace" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/crime_date"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:backgroundTint="@color/crime_surface_soft"
                    android:minHeight="56dp"
                    android:textColor="@color/crime_text_primary"
                    app:cornerRadius="20dp"
                    app:rippleColor="@color/crime_overlay"
                    app:strokeColor="@color/crime_accent_amber"
                    app:strokeWidth="1dp" />

                <CheckBox
                    android:id="@+id/crime_solved"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:buttonTint="@color/crime_accent_green"
                    android:text="@string/crime_solved_label"
                    android:textColor="@color/crime_text_primary"
                    android:textSize="15sp" />

                <CheckBox
                    android:id="@+id/crime_requires_police"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/crime_accent_red"
                    android:text="@string/crime_requires_police_label"
                    android:textColor="@color/crime_text_primary"
                    android:textSize="15sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/crime_surface_elevated"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/crime_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/crime_photo_label"
                    android:textColor="@color/crime_text_muted"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:typeface="monospace" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="@color/crime_surface_soft"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/crime_stroke"
                    app:strokeWidth="1dp">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/crime_photo"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/crime_photo_height"
                        android:adjustViewBounds="false"
                        android:background="@color/crime_surface_soft"
                        android:contentDescription="@string/crime_photo_placeholder_description"
                        android:padding="@dimen/crime_photo_placeholder_padding"
                        android:scaleType="center"
                        android:src="@drawable/ic_camera" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/crime_photo_hint"
                    android:textColor="@color/crime_text_secondary"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/crime_camera"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/crime_surface_soft"
                    android:minHeight="56dp"
                    android:text="@string/crime_capture_photo"
                    android:textColor="@color/crime_text_primary"
                    app:cornerRadius="20dp"
                    app:icon="@drawable/ic_camera"
                    app:iconGravity="textStart"
                    app:iconPadding="10dp"
                    app:iconTint="@color/crime_accent_amber"
                    app:rippleColor="@color/crime_overlay"
                    app:strokeColor="@color/crime_accent_amber"
                    app:strokeWidth="1dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/crime_surface_elevated"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/crime_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/crime_action_panel_label"
                    android:textColor="@color/crime_text_muted"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:typeface="monospace" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/crime_suspect"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/crime_surface_soft"
                    android:minHeight="56dp"
                    android:text="@string/crime_suspect_text"
                    android:textColor="@color/crime_text_primary"
                    app:cornerRadius="20dp"
                    app:rippleColor="@color/crime_overlay"
                    app:strokeColor="@color/crime_accent_amber"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/crime_call_suspect"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/crime_surface_soft"
                    android:enabled="false"
                    android:minHeight="56dp"
                    android:text="@string/crime_call_suspect_text"
                    android:textColor="@color/crime_text_primary"
                    app:cornerRadius="20dp"
                    app:icon="@android:drawable/ic_menu_call"
                    app:iconGravity="textStart"
                    app:iconPadding="10dp"
                    app:iconTint="@color/crime_accent_green"
                    app:rippleColor="@color/crime_overlay"
                    app:strokeColor="@color/crime_accent_green"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/crime_report"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/crime_surface_soft"
                    android:minHeight="56dp"
                    android:text="@string/crime_report_text"
                    android:textColor="@color/crime_text_primary"
                    app:cornerRadius="20dp"
                    app:rippleColor="@color/crime_overlay"
                    app:strokeColor="@color/crime_stroke"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/crime_save"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/crime_accent_amber"
                    android:minHeight="58dp"
                    android:text="@string/crime_save"
                    android:textColor="@color/crime_ink_dark"
                    android:textStyle="bold"
                    app:cornerRadius="20dp"
                    app:rippleColor="@color/crime_overlay"
                    app:strokeColor="@color/crime_overlay"
                    app:strokeWidth="1dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
